generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  PRINCIPAL
  TEACHER
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  GUEST
}

enum SardType {
  INDIVIDUAL
  GROUP
}

enum SardSource {
  LOCAL
  DARUL_QURAN
  AWQAF
}

enum SardKind {
  SARD
  EXAM
}

enum PaymentMethod {
  PALPAL
  JAWWAL_PAY
  MALCHAT
  BANK_PALESTINE
  OTHER
}

enum ClassStatus {
  ACTIVE
  INACTIVE
}

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum RecitationType {
  NEW
  RECENT_REVISION
  OLD_REVISION
}

enum Tone {
  NEUTRAL
  POSITIVE
  WARNING
}

enum MessageChannel {
  INDIVIDUAL
  GROUP
}

enum MessageMode {
  TEMPLATE
  AI
}

// ─── Reference ────────────────────────────────────────────────────────────────

model Surah {
  number    Int    @id
  nameAr    String
  ayahCount Int
  startPage Int
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  fullName     String
  kunya        String?
  email        String   @unique
  passwordHash String
  role         Role     @default(TEACHER)
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Roster import fields (from the center's external teacher database)
  nationalId      String?
  dateOfBirth     DateTime? @db.Date
  maritalStatus   String?
  familySize      Int?
  incomeSource    String?
  qualification   String?
  teachingStage   String?
  roleTitle       String?

  // Relations
  classes          Class[]          @relation("TeacherClasses")
  attendanceLogged AttendanceRecord[] @relation("RecordedByUser")
  hifzLogged       HifzSession[]    @relation("HifzRecordedByUser")
  sardLogged       SardRecord[]     @relation("SardRecordedByUser")
  messageCategories MessageCategory[] @relation("CategoryCreatedByUser")
  messageLogs      MessageLog[]     @relation("MessageCreatedByUser")
}

// ─── Students ─────────────────────────────────────────────────────────────────

model Student {
  id           String        @id @default(cuid())
  fullName     String
  gender       Gender
  dateOfBirth  DateTime?     @db.Date
  photoUrl     String?
  nationalId    String?
  schoolGrade   String?
  neighborhood  String?
  guardianName       String?
  guardianPhone      String?
  secondaryPhone     String?
  guardianOccupation String?
  paymentNumber      String?
  paymentMethod      PaymentMethod?
  previousHifzPages  Int?
  enrollmentDate DateTime    @default(now()) @db.Date
  status       StudentStatus @default(ACTIVE)
  notes        String?

  // Roster import fields (from the center's external student database)
  educationStage   String?
  familySize       Int?
  tajweedLevel     String?
  commitmentLevel  String?
  residencyStatus  String?

  // Snapshot fields (denormalized, updated on each new hifz session)
  currentTotalPagesMemorized Int     @default(0)
  currentJuz                 Int?
  lastSabaqReference         String?

  // FK
  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendanceRecords AttendanceRecord[]
  hifzSessions      HifzSession[]
  sardRecords       SardRecord[]
  messageLogs       MessageLog[]
}

// ─── Classes (Halaqat) ────────────────────────────────────────────────────────

model Class {
  id        String      @id @default(cuid())
  name      String
  level     String?
  location  String?
  capacity  Int?
  status    ClassStatus @default(ACTIVE)
  sponsorship String?
  fundingBody String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // FK
  teacherId String
  teacher   User   @relation("TeacherClasses", fields: [teacherId], references: [id])

  // Relations
  students          Student[]
  scheduleSlots     ScheduleSlot[]
  attendanceRecords AttendanceRecord[]
  hifzSessions      HifzSession[]
  messageLogs       MessageLog[]
}

// ─── Timetable ────────────────────────────────────────────────────────────────

model ScheduleSlot {
  id        String    @id @default(cuid())
  dayOfWeek DayOfWeek
  startTime String
  endTime   String

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId, dayOfWeek])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model AttendanceRecord {
  id     String           @id @default(cuid())
  date   DateTime         @db.Date
  status AttendanceStatus @default(PRESENT)
  notes  String?

  studentId        String
  student          Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId          String
  class            Class   @relation(fields: [classId], references: [id])
  recordedByUserId String
  recordedBy       User    @relation("RecordedByUser", fields: [recordedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

// ─── Hifz Sessions ────────────────────────────────────────────────────────────

model HifzSession {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  generalNotes String?

  studentId        String
  student          Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId          String
  class            Class   @relation(fields: [classId], references: [id])
  recordedByUserId String
  recordedBy       User    @relation("HifzRecordedByUser", fields: [recordedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries RecitationEntry[]

  @@unique([studentId, date])
}

// ─── Recitation Entries ───────────────────────────────────────────────────────

model RecitationEntry {
  id   String         @id @default(cuid())
  type RecitationType

  fromPage Int
  toPage   Int

  fromSurah      Int?
  fromAyah       Int?
  toSurah        Int?
  toAyah         Int?
  linesCount     Int?
  pagesCount     Float?
  surahCompleted Boolean @default(false)

  rating       Int // 1–4
  mistakeCount Int @default(0)
  notes        String?

  hifzSessionId String
  hifzSession   HifzSession @relation(fields: [hifzSessionId], references: [id], onDelete: Cascade)
}

// ─── Parent Messaging ─────────────────────────────────────────────────────────

model MessageCategory {
  id        String   @id @default(cuid())
  name      String
  tone      Tone     @default(NEUTRAL)
  template  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  createdByUserId String
  createdBy       User   @relation("CategoryCreatedByUser", fields: [createdByUserId], references: [id])

  messageLogs MessageLog[]
}

// ─── Sard Records ─────────────────────────────────────────────────────────────

model SardRecord {
  id       String     @id @default(cuid())
  type     SardType
  source   SardSource @default(LOCAL)
  kind     SardKind   @default(SARD)
  date     DateTime   @db.Date
  fromJuz  Int
  toJuz    Int
  rating   Int
  mistakes Int        @default(0)
  notes    String?

  studentId        String
  student          Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recordedByUserId String
  recordedBy       User    @relation("SardRecordedByUser", fields: [recordedByUserId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Telegram Raw Inbox ───────────────────────────────────────────────────────

model RawTelegramMessage {
  id               String   @id @default(cuid())
  telegramUpdateId BigInt?
  chatId           BigInt
  rawText          String
  receivedAt       DateTime @default(now())
  parsed           Boolean  @default(false)
  parseError       String?
}

model MessageLog {
  id      String         @id @default(cuid())
  channel MessageChannel
  mode    MessageMode
  body    String

  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id])
  classId    String?
  class      Class?   @relation(fields: [classId], references: [id])
  categoryId String?
  category   MessageCategory? @relation(fields: [categoryId], references: [id])

  createdByUserId String
  createdBy       User   @relation("MessageCreatedByUser", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
}
